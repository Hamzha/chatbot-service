{
  "name": "rag-modular-js",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "test": "npm run --workspaces test",
    "typecheck": "npm run --workspaces typecheck",
    "dev:api": "npm run --workspace @rag/api dev",
    "dev:ui": "npm run --workspace @rag/ui dev"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^3.25.67"
  }
}
