# Runtime
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8001

# Model provider: openai | ollama
MODEL_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Embeddings (per request)
OLLAMA_TIMEOUT_SECONDS=180
# Chat `/api/generate` read timeout — increase if you see ReadTimeout (large local models)
OLLAMA_GENERATE_TIMEOUT_SECONDS=600

# Vector store
# IMPORTANT: Keep this path aligned with model-gateway-api CHROMA_PERSIST_DIR.
# Both services must point to the same shared Chroma directory to read/write the same vectors.
# Example for this monorepo layout:
# CHROMA_PERSIST_DIR=../../chroma_data
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=chatbot_chunks

# Inngest
INNGEST_APP_ID=chatbot_engine
INNGEST_API_BASE_URL=http://127.0.0.1:8288/v1
INNGEST_EVENT_API_BASE_URL=http://127.0.0.1:8288/
