# Auth
# Long random secret used to sign JWTs — generate with `openssl rand -hex 64`
JWT_SECRET=replace-with-a-long-random-secret
# Access token lifetime in seconds (3600 = 1 hour)
JWT_EXPIRES_IN_SECONDS=3600
# Cost factor for bcrypt password hashing (10 is a sane default)
BCRYPT_SALT_ROUNDS=10

# Database
# MongoDB connection string (e.g. mongodb+srv://user:pass@cluster/...)
MONGODB_URI=
# Database name to use within the MongoDB cluster
MONGODB_DB_NAME=

# Email (Resend)
# API key from https://resend.com used to send transactional emails
RESEND_API_KEY=
# From address for outbound emails (must be a verified Resend sender)
EMAIL_FROM=

# App
# Public URL of the web app — used in emails and absolute redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Route the public chatbot widget to chatbot-api when true; otherwise model-gateway-api
USE_CHATBOT_API=false
