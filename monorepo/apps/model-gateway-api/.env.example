# App metadata
# Display name for the service (shown in logs and health endpoints)
APP_NAME=Model Gateway API
# Environment label: development | staging | production
APP_ENV=development
# Service version — bump on releases
APP_VERSION=0.1.0
# URL prefix for all routes mounted by the API
API_PREFIX=/api

# OpenRouter
# API key from https://openrouter.ai — required for chat and embedding calls
OPEN_ROUTER_API_KEY=
# Default chat model used when a request does not specify one
DEFAULT_MODEL=openai/gpt-oss-120b:free
# Embedding model used for RAG ingestion and queries.
# Set this to an embedding model available for your OpenRouter key/budget.
OPEN_ROUTER_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
